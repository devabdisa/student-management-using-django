# Django Secret Key (REQUIRED)
# Generate a new one: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your_secret_key_here

# Debug Mode (REQUIRED)
# Set to False in production
DEBUG=True

# Allowed Hosts (REQUIRED)
# Comma-separated list of allowed hostnames
# Examples: localhost,127.0.0.1 or example.com,www.example.com
ALLOWED_HOSTS=127.0.0.1,localhost

# Database Configuration (OPTIONAL)
# If not provided, SQLite will be used (db.sqlite3)
# 
# PostgreSQL Example:
# DATABASE_URL=postgresql://username:password@localhost:5432/dilfere_school
#
# PostgreSQL with SSL:
# DATABASE_URL=postgresql://username:password@host:5432/dbname?sslmode=require
#
# Heroku/Cloud PostgreSQL:
# DATABASE_URL=postgres://user:pass@host:5432/dbname
#
DATABASE_URL=sqlite:///db.sqlite3
